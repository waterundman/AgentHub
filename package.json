{
  "name": "agenthub",
  "version": "0.4.0",
  "description": "轻量多 Agent 协作平台 - Git 式版本管理 AI Agent",
  "type": "module",
  "main": "dist/main/main.cjs",
  "author": "AgentHub Team",
  "homepage": "https://github.com/waterundman/AgentHub",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "electron:dev": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "node --max-old-space-size=4096 scripts/build.js",
    "electron:build:win": "cross-env NODE_OPTIONS=--max-old-space-size=4096 node scripts/build.js --win",
    "electron:build:mac": "cross-env NODE_OPTIONS=--max-old-space-size=4096 node scripts/build.js --mac",
    "electron:build:linux": "cross-env NODE_OPTIONS=--max-old-space-size=4096 node scripts/build.js --linux",
    "clean": "rm -rf dist release",
    "clean:all": "rm -rf dist release node_modules/.cache"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "dotenv": "^17.4.1",
    "monaco-editor": "^0.45.0",
    "node-fetch": "^3.3.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.24.2",
    "esbuild-node-externals": "^1.21.0",
    "vite": "^5.2.0",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vitest": "^1.6.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.agenthub.app",
    "productName": "AgentHub",
    "copyright": "Copyright © 2026 AgentHub Team",
    "asar": true,
    "asarUnpack": [
      "dist/main/**/*"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-Portable.exe"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.dmg"
    },
    "appImage": {
      "artifactName": "${productName}-${version}-${arch}.AppImage"
    },
    "extraMetadata": {
      "main": "dist/main/main.cjs"
    }
  },
  "keywords": [
    "agent",
    "ai",
    "collaboration",
    "version-control",
    "electron",
    "desktop-app"
  ],
  "license": "MIT"
}
